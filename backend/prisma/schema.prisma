// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TEACHER
}

enum TaskStatus {
  CREATED
  PROCESSING
  PARTIAL_DONE
  DONE
  FAILED
}

enum SubmissionStatus {
  UPLOADED
  TEXT_EXTRACTING
  TEXT_PENDING_CORRECTION
  TEXT_READY
  AI_PROCESSING
  AI_DONE
  REVIEWED
  FAILED
}

enum FileKind {
  JPG
  PNG
  PDF
}

model User {
  id          String      @id @default(cuid())
  username    String      @unique
  passwordHash String
  role        UserRole
  displayName String
  status      String      @default("ACTIVE")
  classes     Class[]
  essayTasks  EssayTask[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Class {
  id           String      @id @default(cuid())
  name         String
  grade        String?
  academicYear String?
  teacherId    String?
  status       String      @default("ACTIVE")
  teacher      User?       @relation(fields: [teacherId], references: [id])
  students     Student[]
  essayTasks   EssayTask[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Student {
  id         String       @id @default(cuid())
  classId    String
  name       String
  studentNo  String?
  gender     String?
  status     String       @default("ACTIVE")
  class      Class        @relation(fields: [classId], references: [id], onDelete: Restrict)
  submissions Submission[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model EssayTask {
  id            String          @id @default(cuid())
  teacherId     String
  classId       String
  title         String
  note          String?
  topicText     String?
  topicGuidance Json?
  status        TaskStatus      @default(CREATED)
  totalCount    Int             @default(0)
  doneCount     Int             @default(0)
  failedCount   Int             @default(0)
  teacher       User            @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  class         Class           @relation(fields: [classId], references: [id], onDelete: Restrict)
  topicFiles    EssayTopicFile[]
  submissions   Submission[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model EssayTopicFile {
  id            String    @id @default(cuid())
  taskId        String
  filePath      String
  fileName      String
  fileType      FileKind
  extractedText String?
  task          EssayTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
}

model Submission {
  id             String           @id @default(cuid())
  taskId         String
  studentId      String?
  detectedName   String?
  detectedClass  String?
  status         SubmissionStatus @default(UPLOADED)
  reviewedAt     DateTime?
  task           EssayTask        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  student        Student?         @relation(fields: [studentId], references: [id], onDelete: SetNull)
  files          SubmissionFile[]
  text           SubmissionText?
  review         Review?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model SubmissionFile {
  id           String     @id @default(cuid())
  submissionId String
  filePath     String
  fileName     String
  fileType     FileKind
  pageCount    Int?       @default(1)
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}

model SubmissionText {
  id           String     @id @default(cuid())
  submissionId String     @unique
  ocrText      String?
  correctedText String?
  textVersion  Int        @default(1)
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Review {
  id               String     @id @default(cuid())
  submissionId     String     @unique
  aiSummary        String?
  aiStrengths      String?
  aiIssues         String?
  aiSuggestions    String?
  aiRewriteExample String?
  scoreTotal       Int?
  scoreContent     Int?
  scoreStructure   Int?
  scoreLanguage    Int?
  scoreIdea        Int?
  teacherComment   String?
  finalComment     String?
  printableSnapshot Json?
  submission       Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}
