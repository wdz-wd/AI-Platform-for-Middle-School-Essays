DATABASE_URL="postgresql://postgres:your-postgres-password@localhost:5432/essay_review?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
UPLOAD_DIR="../uploads"
OCR_PROVIDER="baidu"
BAIDU_OCR_API_KEY="your-baidu-ocr-api-key"
BAIDU_OCR_SECRET_KEY="your-baidu-ocr-secret-key"
BAIDU_OCR_TOKEN_URL="https://aip.baidubce.com/oauth/2.0/token"
BAIDU_OCR_POLL_INTERVAL_MS=4000
BAIDU_OCR_MAX_ATTEMPTS=16
BAIDU_OCR_REFRESH_BUFFER_MS=86400000
PADDLE_OCR_API_URL="https://your-aistudio-app.com/layout-parsing"
PADDLE_OCR_TOKEN="your-paddle-ocr-token"
PADDLE_OCR_USE_DOC_ORIENTATION_CLASSIFY=false
PADDLE_OCR_USE_DOC_UNWARPING=false
DEEPSEEK_API_KEY="your-deepseek-api-key"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"
APP_ORIGIN="http://localhost:5173"
PORT=3000
